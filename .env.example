# ============================================================
# OpenClaw – Empleado Digital Personal
# Variables de entorno  (copiar a .env y editar)
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=openclaw

# --- URL de conexión (el servicio "postgres" se resuelve por Docker DNS) ---
DATABASE_URL=postgresql://openclaw:changeme_secure_password@postgres:5432/openclaw

# --- Timezone ---
TZ=America/Argentina/Buenos_Aires

# --- API Key del proveedor de LLM (ej: OpenAI, Anthropic, Google, etc.) ---
# Poné tu key acá. Ejemplo para OpenAI:
#   OPENCLAW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENCLAW_API_KEY=

# --- Modelo preferido (opcional) ---
# Ejemplos: gpt-4o, claude-sonnet-4-20250514, gemini-2.5-pro, etc.
OPENCLAW_MODEL=

# --- Puerto interno de OpenClaw (no cambiar salvo necesidad) ---
OPENCLAW_PORT=18789

# --- Puerto del host (solo si descomentás "ports" en docker-compose.yml) ---
HOST_PORT=18789
